private void btnSave_Click(object sender, EventArgs e)
{
    // 1. Валидация: выбран ли отдел и статья
    if (comboBoxDepartment.SelectedIndex == -1 || comboBoxItem.SelectedIndex == -1)
    {
        MessageBox.Show("Выберите отдел и статью затрат.");
        return;
    }
    
    // 2. Извлекаем ID из ComboBox (там хранится ID, отображается имя)
    SelectedDepartmentId = Convert.ToInt32(comboBoxDepartment.SelectedValue);
    SelectedItemId = Convert.ToInt32(comboBoxItem.SelectedValue);
    
    // 3. Проверка года
    if (!int.TryParse(textBoxYear.Text, out int year) || year < 2020)
    {
        MessageBox.Show("Введите корректный год (не менее 2020).");
        return;
    }
    Year = year;
    
    // 4. Проверка суммы
    if (!decimal.TryParse(textBoxAmount.Text, out decimal amount) || amount < 0)
    {
        MessageBox.Show("Введите корректную сумму (неотрицательное число).");
        return;
    }
    Amount = amount;
    
    // 5. Закрываем форму с результатом OK
    DialogResult = DialogResult.OK;
    Close();
}

public void SetEditData(int deptId, int itemId, int year, decimal amount)
{
    // Устанавливаем значения в элементы управления
    comboBoxDepartment.SelectedValue = deptId;
    comboBoxItem.SelectedValue = itemId;
    textBoxYear.Text = year.ToString();
    textBoxAmount.Text = amount.ToString();
}

private void btnGenerateReport_Click(object sender, EventArgs e)
{
    // 1. Проверка: выбраны ли статьи затрат
    if (checkedListBoxItems.CheckedItems.Count == 0)
    {
        MessageBox.Show("Выберите хотя бы одну статью затрат.");
        return;
    }
    
    // 2. Собираем выбранные статьи в список строк
    List<string> selectedItems = new List<string>();
    foreach (var item in checkedListBoxItems.CheckedItems)
    {
        selectedItems.Add(item.ToString());
    }
    
    // 3. Формируем SQL-запрос: выбираем статьи и суммы за период
    string itemsList = string.Join(",", selectedItems.Select(s => $"'{s}'")); // например 'Реклама','Командировки'
    
    string sql = $@"
        SELECT i.item_name AS ""Статья"", 
               SUM(a.amount) AS ""Сумма""
        FROM actual_expenses a
        JOIN expense_items i ON a.item_id = i.item_id
        WHERE a.expense_date BETWEEN @from AND @to
        AND i.item_name IN ({itemsList})
        GROUP BY i.item_name
        ORDER BY ""Сумма"" DESC";
    
    // 4. Выполняем запрос
    DataTable reportTable = DatabaseHelper.ExecuteQuery(sql, 
        new Npgsql.NpgsqlParameter("@from", dateTimePickerFrom.Value.Date),
        new Npgsql.NpgsqlParameter("@to", dateTimePickerTo.Value.Date));
    
    // 5. Отображаем таблицу
    dataGridViewReport.DataSource = reportTable;
    
    // 6. Строим диаграмму
    BuildChart(reportTable);
}

private void btnExportExcel_Click(object sender, EventArgs e)
{
    // 1. Проверка: есть ли данные для экспорта
    if (dataGridViewReport.Rows.Count == 0)
    {
        MessageBox.Show("Сначала сформируйте отчет.");
        return;
    }
    
    // 2. Диалог сохранения файла
    using (SaveFileDialog sfd = new SaveFileDialog() 
    { 
        Filter = "Excel Files|*.xlsx", 
        Title = "Сохранить отчет в Excel",
        FileName = "Отчет_по_затратам.xlsx"
    })
    {
        if (sfd.ShowDialog() == DialogResult.OK)
        {
            // 3. Создаем Excel-файл через EPPlus
            using (var package = new OfficeOpenXml.ExcelPackage())
            {
                var worksheet = package.Workbook.Worksheets.Add("Отчет по затратам");
                
                // 4. Записываем заголовки колонок
                for (int c = 0; c < dataGridViewReport.Columns.Count; c++)
                {
                    worksheet.Cells[1, c + 1].Value = dataGridViewReport.Columns[c].HeaderText;
                }
                
                // 5. Записываем данные строк
                for (int r = 0; r < dataGridViewReport.Rows.Count; r++)
                {
                    for (int c = 0; c < dataGridViewReport.Columns.Count; c++)
                    {
                        var val = dataGridViewReport.Rows[r].Cells[c].Value;
                        worksheet.Cells[r + 2, c + 1].Value = val != null ? val.ToString() : "";
                    }
                }
                
                // 6. Автоподбор ширины колонок
                worksheet.Cells.AutoFitColumns();
                
                // 7. Сохраняем файл
                package.SaveAs(sfd.FileName);
            }
            
            MessageBox.Show($"Отчет успешно экспортирован!\nФайл: {sfd.FileName}");
        }
    }
}

private void BuildChart(DataTable dt)
{
    // Очищаем старые данные
    chart1.Series.Clear();
    
    // Создаем новую серию (столбцовую диаграмму)
    var series = new System.Windows.Forms.DataVisualization.Charting.Series
    {
        Name = "Затраты",
        ChartType = System.Windows.Forms.DataVisualization.Charting.SeriesChartType.Column
    };
    
    // Добавляем точки данных из таблицы
    foreach (DataRow row in dt.Rows)
    {
        string category = row["Статья"].ToString();
        decimal amount = Convert.ToDecimal(row["Сумма"]);
        series.Points.AddXY(category, amount);
    }
    
    // Добавляем серию на диаграмму
    chart1.Series.Add(series);
    
    // Настраиваем поворот подписей оси X, чтобы не наезжали друг на друга
    chart1.ChartAreas[0].AxisX.LabelStyle.Angle = -45;
}

public static int ExecuteNonQuery(string sql, params Npgsql.NpgsqlParameter[] parameters)
{
    using (var conn = new NpgsqlConnection(ConnectionString))
    {
        conn.Open();
        using (var cmd = new NpgsqlCommand(sql, conn))
        {
            if (parameters != null) cmd.Parameters.AddRange(parameters);
            return cmd.ExecuteNonQuery();
        }
    }
}

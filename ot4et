using System;
using System.Data;
using System.Linq;
using System.Windows.Forms;
using OfficeOpenXml; // NuGet: EPPlus
using System.Windows.Forms.DataVisualization.Charting;

namespace KovtunenkoTask
{
    public partial class ReportForm : Form
    {
        public ReportForm()
        {
            InitializeComponent();
            // Устанавливаем текущие даты для фильтра
            dateTimePickerFrom.Value = new DateTime(DateTime.Now.Year, 1, 1);
            dateTimePickerTo.Value = DateTime.Now;
            
            // Загружаем статьи затрат в CheckedListBox
            DataTable items = DatabaseHelper.ExecuteQuery("SELECT item_id, item_name FROM expense_items ORDER BY item_name");
            foreach (DataRow row in items.Rows)
            {
                checkedListBoxItems.Items.Add(row["item_name"].ToString());
            }
        }

        private void btnGenerateReport_Click(object sender, EventArgs e)
        {
            if (checkedListBoxItems.CheckedItems.Count == 0)
            {
                MessageBox.Show("Выберите хотя бы одну статью затрат.");
                return;
            }

            string[] selectedItems = checkedListBoxItems.CheckedItems.Cast<string>().ToArray();
            string itemsList = string.Join(",", selectedItems.Select(s => $"'{s}'"));

            string sql = $@"
                SELECT i.item_name AS Статья, SUM(a.amount) AS Сумма
                FROM actual_expenses a
                JOIN expense_items i ON a.item_id = i.item_id
                WHERE a.expense_date BETWEEN @from AND @to
                AND i.item_name IN ({itemsList})
                GROUP BY i.item_name
                ORDER BY Сумма DESC";

            DataTable reportTable = DatabaseHelper.ExecuteQuery(sql, 
                new Npgsql.NpgsqlParameter("@from", dateTimePickerFrom.Value.Date),
                new Npgsql.NpgsqlParameter("@to", dateTimePickerTo.Value.Date));

            dataGridViewReport.DataSource = reportTable;

            // Строим диаграмму
            BuildChart(reportTable);
        }

        private void BuildChart(DataTable dt)
        {
            chart1.Series.Clear();
            var series = new System.Windows.Forms.DataVisualization.Charting.Series
            {
                Name = "Затраты",
                ChartType = SeriesChartType.Column
            };

            foreach (DataRow row in dt.Rows)
            {
                string category = row["Статья"].ToString();
                decimal amount = Convert.ToDecimal(row["Сумма"]);
                series.Points.AddXY(category, amount);
            }

            chart1.Series.Add(series);
            chart1.ChartAreas[0].AxisX.LabelStyle.Angle = -45;
        }

        private void btnExportExcel_Click(object sender, EventArgs e)
        {
            if (dataGridViewReport.Rows.Count == 0)
            {
                MessageBox.Show("Сначала сформируйте отчет.");
                return;
            }

            using (SaveFileDialog sfd = new SaveFileDialog() { Filter = "Excel Files|*.xlsx" })
            {
                if (sfd.ShowDialog() == DialogResult.OK)
                {
                    // Экспорт через EPPlus (требуется установка через NuGet)
                    using (var package = new ExcelPackage())
                    {
                        var worksheet = package.Workbook.Worksheets.Add("Отчет по затратам");
                        
                        // Заголовки
                        for (int c = 0; c < dataGridViewReport.Columns.Count; c++)
                        {
                            worksheet.Cells[1, c + 1].Value = dataGridViewReport.Columns[c].HeaderText;
                        }
                        
                        // Данные
                        for (int r = 0; r < dataGridViewReport.Rows.Count; r++)
                        {
                            for (int c = 0; c < dataGridViewReport.Columns.Count; c++)
                            {
                                worksheet.Cells[r + 2, c + 1].Value = dataGridViewReport.Rows[r].Cells[c].Value?.ToString() ?? "";
                            }
                        }

                        worksheet.Cells.AutoFitColumns();
                        package.SaveAs(sfd.FileName);
                    }
                    MessageBox.Show("Отчет экспортирован!");
                }
            }
        }
    }
}
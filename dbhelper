using Npgsql;
using System;
using System.Data;

namespace KovtunenkoTask
{
    public static class DatabaseHelper
    {
        // ЗАМЕНИТЕ НА СВОИ ДАННЫЕ!
        private const string ConnectionString = "Host=localhost;Port=5432;Database=KovtunenkoDB;Username=postgres;Password=123456";

        public static DataTable ExecuteQuery(string sql, params NpgsqlParameter[] parameters)
        {
            using (var conn = new NpgsqlConnection(ConnectionString))
            {
                conn.Open();
                using (var cmd = new NpgsqlCommand(sql, conn))
                {
                    if (parameters != null) cmd.Parameters.AddRange(parameters);
                    using (var reader = cmd.ExecuteReader())
                    {
                        DataTable dt = new DataTable();
                        dt.Load(reader);
                        return dt;
                    }
                }
            }
        }

        public static int ExecuteNonQuery(string sql, params NpgsqlParameter[] parameters)
        {
            using (var conn = new NpgsqlConnection(ConnectionString))
            {
                conn.Open();
                using (var cmd = new NpgsqlCommand(sql, conn))
                {
                    if (parameters != null) cmd.Parameters.AddRange(parameters);
                    return cmd.ExecuteNonQuery();
                }
            }
        }
    }
}

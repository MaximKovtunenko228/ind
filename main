using System;
using System.Data;
using System.Windows.Forms;

namespace KovtunenkoTask
{
    public partial class Form1 : Form
    {
        private DataTable masterTable;
        private DataTable detailTable;

        public Form1()
        {
            InitializeComponent();
            LoadData();
            SetupMasterDetail();
        }

        private void LoadData()
        {
            // Мастер: Плановые затраты с именами вместо ID
            string sqlMaster = @"
                SELECT p.plan_id, d.department_name AS Отдел, i.item_name AS Статья, 
                       p.plan_year AS Год, p.planned_amount AS План
                FROM planned_expenses p
                JOIN departments d ON p.department_id = d.department_id
                JOIN expense_items i ON p.item_id = i.item_id
                ORDER BY d.department_name";
            
            masterTable = DatabaseHelper.ExecuteQuery(sqlMaster);
            dataGridViewMaster.DataSource = masterTable;
            
            // Скрываем ID
            dataGridViewMaster.Columns["plan_id"].Visible = false;
        }

        private void SetupMasterDetail()
        {
            // При выборе строки в master обновляем detail
            dataGridViewMaster.SelectionChanged += DataGridViewMaster_SelectionChanged;
        }

        private void DataGridViewMaster_SelectionChanged(object sender, EventArgs e)
        {
            if (dataGridViewMaster.SelectedRows.Count > 0)
            {
                // Получаем department_id и item_id из выделенной строки
                // Для простоты извлекаем ID через скрытые столбцы или через запрос к БД по названиям
                int planId = Convert.ToInt32(dataGridViewMaster.SelectedRows[0].Cells["plan_id"].Value);
                
                // Чтобы получить department_id и item_id, лучше сделать отдельный запрос по plan_id
                string sqlIds = $"SELECT department_id, item_id FROM planned_expenses WHERE plan_id = {planId}";
                var dtIds = DatabaseHelper.ExecuteQuery(sqlIds);
                
                if (dtIds.Rows.Count > 0)
                {
                    int deptId = Convert.ToInt32(dtIds.Rows[0]["department_id"]);
                    int itemId = Convert.ToInt32(dtIds.Rows[0]["item_id"]);

                    // Загружаем фактические затраты по этим отделу и статье
                    string sqlDetail = $@"
                        SELECT a.actual_id, a.expense_date AS Дата, a.amount AS Сумма, a.note AS Примечание
                        FROM actual_expenses a
                        WHERE a.department_id = {deptId} AND a.item_id = {itemId}
                        ORDER BY a.expense_date";

                    detailTable = DatabaseHelper.ExecuteQuery(sqlDetail);
                    dataGridViewDetail.DataSource = detailTable;
                    dataGridViewDetail.Columns["actual_id"].Visible = false;
                }
            }
        }

        // --- CRUD Кнопки ---

        private void btnAddMaster_Click(object sender, EventArgs e)
        {
            // Открываем форму редактирования в режиме добавления (id = 0)
            using (var form = new AddEditForm(0)) 
            {
                if (form.ShowDialog() == DialogResult.OK)
                {
                    DatabaseHelper.ExecuteNonQuery(
                        "INSERT INTO planned_expenses (department_id, item_id, plan_year, planned_amount) VALUES (@deptId, @itemId, @year, @amount)",
                        new Npgsql.NpgsqlParameter("@deptId", form.SelectedDepartmentId),
                        new Npgsql.NpgsqlParameter("@itemId", form.SelectedItemId),
                        new Npgsql.NpgsqlParameter("@year", form.Year),
                        new Npgsql.NpgsqlParameter("@amount", form.Amount)
                    );
                    LoadData(); // Обновить таблицы
                }
            }
        }

        private void btnEditMaster_Click(object sender, EventArgs e)
        {
            if (dataGridViewMaster.SelectedRows.Count == 0) return;
            int planId = Convert.ToInt32(dataGridViewMaster.SelectedRows[0].Cells["plan_id"].Value);
            
            // Получаем текущие данные для редактирования
            string sql = $"SELECT * FROM planned_expenses WHERE plan_id = {planId}";
            var dt = DatabaseHelper.ExecuteQuery(sql);
            if (dt.Rows.Count == 0) return;

            using (var form = new AddEditForm(planId))
            {
                // Предзаполняем форму
                form.SetEditData(Convert.ToInt32(dt.Rows[0]["department_id"]), 
                                 Convert.ToInt32(dt.Rows[0]["item_id"]),
                                 Convert.ToInt32(dt.Rows[0]["plan_year"]),
                                 Convert.ToDecimal(dt.Rows[0]["planned_amount"]));
                
                if (form.ShowDialog() == DialogResult.OK)
                {
                    // Обновляем запись, а не вводим заново
                    DatabaseHelper.ExecuteNonQuery(
                        "UPDATE planned_expenses SET department_id=@deptId, item_id=@itemId, plan_year=@year, planned_amount=@amount WHERE plan_id=@planId",
                        new Npgsql.NpgsqlParameter("@deptId", form.SelectedDepartmentId),
                        new Npgsql.NpgsqlParameter("@itemId", form.SelectedItemId),
                        new Npgsql.NpgsqlParameter("@year", form.Year),
                        new Npgsql.NpgsqlParameter("@amount", form.Amount),
                        new Npgsql.NpgsqlParameter("@planId", planId)
                    );
                    LoadData();
                }
            }
        }

        private void btnDeleteMaster_Click(object sender, EventArgs e)
        {
            if (dataGridViewMaster.SelectedRows.Count == 0) return;
            if (MessageBox.Show("Удалить выбранную плановую запись?", "Подтверждение", MessageBoxButtons.YesNo) == DialogResult.Yes)
            {
                int planId = Convert.ToInt32(dataGridViewMaster.SelectedRows[0].Cells["plan_id"].Value);
                DatabaseHelper.ExecuteNonQuery("DELETE FROM planned_expenses WHERE plan_id = @id", new Npgsql.NpgsqlParameter("@id", planId));
                LoadData();
            }
        }

        // Аналогичные кнопки для Detail (Фактические затраты)
        // btnAddDetail, btnEditDetail, btnDeleteDetail
        // ... (реализуются по аналогии с Master, но для actual_expenses)

        private void btnOpenReport_Click(object sender, EventArgs e)
        {
            ReportForm reportForm = new ReportForm();
            reportForm.ShowDialog();
        }
    }
}